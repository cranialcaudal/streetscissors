<%= if @category in ["sensus", "reflections"] do %>
  <div
    class={["sensus-portal", @category == "reflections" && "blog-portal"]}
    style="grid-template-areas: 'nav main sidebar'; grid-template-rows: 1fr;"
  >
    
<!-- LEFT RAIL: FIXED NAVIGATION -->
    <nav class="sensus-rail">
      <div class="sensus-brand">
        <%= if @category == "sensus" do %>
          <img
            src={~p"/images/latent_sensus_icon.png"}
            alt="Latent Sensus"
            class="sensus-brand-icon"
          />
          <h1>The Latent Sensus</h1>
        <% else %>
          <div class="blog-brand-icon"><i class="fas fa-pen-nib"></i></div>
          <h1>Another Blog</h1>
        <% end %>
        <div class="sensus-rail-sub">
          {if @category == "sensus",
            do: "Blog & Podcast Archive",
            else: "Personal Thoughts & Physical Drafts"}
        </div>
      </div>

      <div
        class="sensus-bio"
        style="font-size: 0.8rem; color: #555; line-height: 1.5; border-bottom: 1px solid var(--sensus-border); padding-bottom: 1.5rem;"
      >
        <%= if @category == "sensus" do %>
          An honest exploration of complex ideas through AI-assisted drafts, human editing, and long-form readings. Finding the "latent sense" of philosophy, politics, and culture.
        <% else %>
          Handwritten Cesar-slop. No artificial sweeteners or preservatives. No LLM guiding or coercion. My reflections, thoughts, and prayers.
        <% end %>
      </div>

      <ul class="sensus-nav-list">
        <li>
          <a
            href={if @category == "sensus", do: ~p"/blog/latent-sensus", else: ~p"/blog/another-blog"}
            class="sensus-nav-link"
          >
            <i class="fas fa-layer-group"></i> Latest
          </a>
        </li>
        <li>
          <a href={~p"/manuscripts"} class="sensus-nav-link">
            <i class="fas fa-file-alt"></i> All Manuscripts
          </a>
        </li>
        <li>
          <a
            href={if @category == "sensus", do: ~p"/blog/another-blog", else: ~p"/blog/latent-sensus"}
            class="sensus-nav-link"
          >
            <i class={
              if @category == "sensus", do: "fas fa-pen-nib", else: "fas fa-microphone-alt"
            }>
            </i>
            {if @category == "sensus", do: "Another Blog", else: "Latent Sensus"}
          </a>
        </li>
      </ul>

      <div style="flex-grow: 1;"></div>
      <div style="font-size: 0.7rem; color: #333; font-family: var(--sensus-font-mono);">
        v3.2.0-ELIXIR-SLEEK
      </div>
    </nav>
    
<!-- MAIN CONTENT -->
    <main class="sensus-main">
      <div
        class={["glass-panel", @category == "reflections" && "blog-prose"]}
        style="padding: 3rem; min-height: 80vh; position: relative;"
      >
        <div class="prose">
          {Phoenix.HTML.raw(@content)}
        </div>
      </div>
    </main>
    
<!-- SIDEBAR -->
    <aside class="sensus-aside">
      <div class="sensus-aside-block">
        <h3>Recent Posts</h3>
        <ul class="sensus-archive-list">
          <%= for file <- @recent_files do %>
            <li class="sensus-archive-item">
              <a
                href={
                  ~p"/manuscripts/#{@category}/#{if @category == "sensus" and file.slug == "the-good-citizen", do: "good_citizen", else: file.slug}"
                }
                class="sensus-archive-link"
                style={
                  if file.slug == @slug,
                    do: "color: var(--sensus-accent); font-weight: bold;",
                    else: ""
                }
              >
                <span>{file.title}</span>
              </a>
            </li>
          <% end %>
        </ul>
      </div>
    </aside>
  </div>
<% else %>
  <div class="container" style="padding-top: 2rem;">
    <div class="glass-panel" style="padding: 3rem; min-height: 80vh;">
      <div class="prose">
        {Phoenix.HTML.raw(@content)}
      </div>
    </div>
  </div>
<% end %>
